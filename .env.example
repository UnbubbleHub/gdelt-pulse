# Copy to .env and set DATABASE_URL.
#
# DATABASE_URL is the single source of truth for the database connection,
# used identically in local dev, Docker Compose, Vercel, and Railway.

# ── Required ───────────────────────────────────────────────────────────

# Pick ONE form for DATABASE_URL:

# (1) Neon / cloud Postgres — recommended for local dev (matches production)
#     Get the connection string from neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# (2) Docker Compose (offline dev)
#     Run `docker compose up -d db`. The DB is exposed on localhost:5432
#     with fixed local creds (gdelt/gdelt) — no secret to manage.
# DATABASE_URL=postgresql://gdelt:gdelt@localhost:5432/gdelt_pulse

# (3) Locally installed Postgres (Homebrew, Postgres.app, etc.)
# DATABASE_URL=postgresql://your_user:your_password@localhost:5432/gdelt_pulse


# ── Optional ───────────────────────────────────────────────────────────

# How often the ingestion → embed → cluster cycle runs (seconds, default 900)
# PIPELINE_INTERVAL=900

# Delete articles older than this many hours (default 168 = 7 days; 0 to disable)
# RETENTION_HOURS=168

# Embedding backend (fastembed is the only supported option)
# EMBEDDING_BACKEND=fastembed

# Healthchecks.io dead-man-switch URL. The runner pings this after every
# successful cycle; the service alerts if no ping arrives within the grace
# period configured at healthchecks.io (suggested: 25 min for a 15-min cycle).
# HEALTHCHECKS_PING_URL=https://hc-ping.com/<your-uuid>


# ── Auth (only required for /dashboard and /api/auth/keys) ─────────────

# Create a Clerk app at https://clerk.com and copy the values below.
# Only the Publishable Key and JWKS URL are needed — the Secret Key is NOT
# used (backend JWT verification reads the public JWKS endpoint directly).
# CLERK_PUBLISHABLE_KEY=pk_test_...
# JWKS URL: Clerk dashboard → API Keys → Advanced → JWT verification
# CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
