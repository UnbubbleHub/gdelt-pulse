# Copy to .env and fill in before running docker compose up

# Database
POSTGRES_USER=gdelt
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=gdelt_pulse

# API — comma-separated allowed origins (no wildcard in production)
CORS_ORIGINS=https://yourdomain.com,https://unbubblenews.com

# Domain for automatic HTTPS via Caddy (leave empty to skip Caddy)
DOMAIN=pulse.yourdomain.com
